generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  password      String
  phone         String?
  dob           String?
  gender        String?
  location      String?
  height        Float?
  weight        Float?
  targetWeight  Float?
  bodyFat       Float?
  muscleMass    Float?
  bmi           Float?
  fitnessGoal   String?
  dietType      String?
  activityLevel String?
  calorieGoal   Int?      @default(2000)
  proteinGoal   Int?      @default(150)
  carbGoal      Int?      @default(250)
  fatGoal       Int?      @default(65)
  waterGoal     Float?    @default(2.5)
  sleepGoal     Float?    @default(8)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @default(now()) @updatedAt
  meals         Meal[]
  workouts      Workout[]
  badges        UserBadge[]
  posts         Post[]
  waterLogs     WaterLog[]
  weightLogs    WeightLog[]
  savedRecipes  Recipe[]
}

model Meal {
  id        String   @id @default(cuid())
  userId    String
  name      String
  calories  Float
  protein   Float    @default(0)
  carbs     Float    @default(0)
  fat       Float    @default(0)
  mealType  String   @default("Breakfast")
  date      DateTime @default(now())
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workout {
  id          String   @id @default(cuid())
  userId      String
  name        String
  duration    Int
  calories    Int
  category    String?
  difficulty  String?
  completedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  emoji       String
  description String
  category    String
  rarity      String
  xp          Int
  userBadges  UserBadge[]
}

model UserBadge {
  id         String   @id @default(cuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id])
  @@unique([userId, badgeId])
}

model Post {
  id        String   @id @default(cuid())
  userId    String
  content   String
  image     String?
  likes     Int      @default(0)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  amountMl  Int      // Amount in milliliters
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  weight    Float
  date      DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Recipe {
  id          String   @id @default(cuid())
  userId      String
  title       String
  ingredients String
  instructions String
  calories    Float?
  protein     Float?
  carbs       Float?
  fat         Float?
  imageUrl    String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
